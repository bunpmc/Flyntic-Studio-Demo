<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Flyntic Studio</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- Three.js Import Map -->
    @Html.Raw(@"
    <script type=""importmap"">
        {
            ""imports"": {
                ""three"": ""https://unpkg.com/three@0.160.0/build/three.module.js"",
                ""three/addons/"": ""https://unpkg.com/three@0.160.0/examples/jsm/""
            }
        }
    </script>
    ")
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand navbar-dark bg-dark studio-navbar">
        <div class="container-fluid">
            <!-- Logo -->
            <a class="navbar-brand studio-logo" href="#">
                Flyntic Studio
            </a>
            
            <!-- Menu Items -->
            <ul class="navbar-nav me-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link" href="#" data-bs-toggle="dropdown">File</a>
                    <ul class="dropdown-menu dropdown-menu-dark">
                        <li><a class="dropdown-item" href="#" onclick="newProject()">New Project</a></li>
                        <li><a class="dropdown-item" href="#">Open Project</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="#">Save</a></li>
                        <li><a class="dropdown-item" href="#">Save As...</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="#">Export</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link" href="#" data-bs-toggle="dropdown">Edit</a>
                    <ul class="dropdown-menu dropdown-menu-dark">
                        <li><a class="dropdown-item" href="#">Undo</a></li>
                        <li><a class="dropdown-item" href="#">Redo</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="#">Cut</a></li>
                        <li><a class="dropdown-item" href="#">Copy</a></li>
                        <li><a class="dropdown-item" href="#">Paste</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="#" onclick="deleteSelected()">Delete</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link" href="#" data-bs-toggle="dropdown">Assets</a>
                    <ul class="dropdown-menu dropdown-menu-dark">
                        <li><a class="dropdown-item" href="#">Import Asset</a></li>
                        <li><a class="dropdown-item" href="#">Manage Components</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link" href="#" data-bs-toggle="dropdown">Objects</a>
                    <ul class="dropdown-menu dropdown-menu-dark">
                        <li><a class="dropdown-item" href="#">Add Frame</a></li>
                        <li><a class="dropdown-item" href="#">Add Motor</a></li>
                        <li><a class="dropdown-item" href="#">Add Battery</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link" href="#" data-bs-toggle="dropdown">Components</a>
                    <ul class="dropdown-menu dropdown-menu-dark">
                        <li><a class="dropdown-item" href="#">Flight Controller</a></li>
                        <li><a class="dropdown-item" href="#">ESC</a></li>
                        <li><a class="dropdown-item" href="#">Camera</a></li>
                        <li><a class="dropdown-item" href="#">GPS</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link" href="#" data-bs-toggle="dropdown">Window</a>
                    <ul class="dropdown-menu dropdown-menu-dark">
                        <li><a class="dropdown-item" href="#">Toggle Hierarchy</a></li>
                        <li><a class="dropdown-item" href="#">Toggle Monitors</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="#">Fullscreen</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link" href="#" data-bs-toggle="dropdown">Help</a>
                    <ul class="dropdown-menu dropdown-menu-dark">
                        <li><a class="dropdown-item" href="#">Documentation</a></li>
                        <li><a class="dropdown-item" href="#">Keyboard Shortcuts</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="#">About</a></li>
                    </ul>
                </li>
            </ul>
            
            <div class="simulation-controls mx-auto">
                <button class="btn btn-outline-info btn-sm" id="btnWiring" onclick="toggleWiringMode()" title="Wiring Mode">
                    <i class="bi bi-connector-plus"></i> Wiring
                </button>
                <button class="btn btn-outline-secondary btn-sm" id="btnTidy" onclick="toggleTidyWires()" title="Tidy/Sag Wires">
                    <i class="bi bi-distribute-vertical"></i> Tidy
                </button>
                <button class="btn btn-outline-success btn-sm" id="btnPlay" onclick="playSimulation()" title="Play">
                    <i class="bi bi-play-fill"></i>
                </button>
                <button class="btn btn-outline-warning btn-sm" id="btnPause" onclick="pauseSimulation()" title="Pause" disabled>
                    <i class="bi bi-pause-fill"></i>
                </button>
                <button class="btn btn-outline-danger btn-sm" id="btnStop" onclick="stopSimulation()" title="Stop">
                    <i class="bi bi-stop-fill"></i>
                </button>
            </div>
            
            <!-- Right side info -->
            <div class="navbar-text text-light">
                <small id="simulationStatus" class="badge bg-secondary">Stopped</small>
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <div class="studio-container">
        @RenderBody()
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.5/axios.min.js"></script>
    <script src="~/js/drone-studio.js" asp-append-version="true"></script>
    <script type="module" src="~/js/main.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
